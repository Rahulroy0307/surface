<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Calculator with History Button</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    .calculator {
      max-width: 320px;
      margin: 20px auto 10px;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }
    .display {
      font-size: 24px;
      height: 50px;
      text-align: right;
      padding: 10px;
      margin-bottom: 10px;
      border-radius: 6px;
      background-color: #f8f9fa;
      user-select: none;
    }
    #historyContainer {
      max-width: 320px;
      margin: 10px auto 30px;
      background: #f1f3f5;
      border-radius: 6px;
      padding: 10px;
      height: 140px;
      overflow-y: auto;
      font-family: monospace;
      white-space: pre-wrap;
      display: none;
    }
  </style>
</head>
<body>
  <div class="calculator bg-light">
    <div id="display" class="display">0</div>
    <div class="d-grid gap-2">
      <div class="btn-group" role="group">
        <button class="btn btn-secondary" onclick="clearDisplay()">C</button>
        <button class="btn btn-secondary" onclick="deleteLast()">←</button>
        <button class="btn btn-secondary" onclick="appendMinus()">±</button>
        <button class="btn btn-secondary" onclick="appendOperator('/')">÷</button>
      </div>
      <div class="btn-group" role="group">
        <button class="btn btn-light" onclick="appendNumber('7')">7</button>
        <button class="btn btn-light" onclick="appendNumber('8')">8</button>
        <button class="btn btn-light" onclick="appendNumber('9')">9</button>
        <button class="btn btn-secondary" onclick="appendOperator('*')">×</button>
      </div>
      <div class="btn-group" role="group">
        <button class="btn btn-light" onclick="appendNumber('4')">4</button>
        <button class="btn btn-light" onclick="appendNumber('5')">5</button>
        <button class="btn btn-light" onclick="appendNumber('6')">6</button>
        <button class="btn btn-secondary" onclick="appendOperator('-')">−</button>
      </div>
      <div class="btn-group" role="group">
        <button class="btn btn-light" onclick="appendNumber('1')">1</button>
        <button class="btn btn-light" onclick="appendNumber('2')">2</button>
        <button class="btn btn-light" onclick="appendNumber('3')">3</button>
        <button class="btn btn-secondary" onclick="appendOperator('+')">+</button>
      </div>
      <div class="btn-group" role="group">
        <button class="btn btn-light" onclick="appendNumber('0')">0</button>
        <button class="btn btn-light" onclick="appendDecimal()">.</button>
        <button class="btn btn-primary" onclick="calculateResult()">=</button>
      </div>
    </div>
  </div>

  <button id="toggleHistoryBtn" class="btn btn-outline-primary d-block mx-auto mb-3" onclick="toggleHistory()">Show History</button>
  <div id="historyContainer"></div>

  <script>
    let expression = '';
    let history = [];

    function updateDisplay() {
      const display = document.getElementById('display');
      display.textContent = expression || '0';
    }

    function appendNumber(num) {
      expression += num;
      updateDisplay();
    }

    function appendOperator(op) {
      if (!expression) return;
      const lastChar = expression.slice(-1);
      if ('+-/*'.includes(lastChar)) {
        expression = expression.slice(0, -1) + op;
      } else {
        expression += op;
      }
      updateDisplay();
    }

    function appendDecimal() {
      const lastOperatorIndex = Math.max(expression.lastIndexOf('+'), expression.lastIndexOf('-'), expression.lastIndexOf('*'), expression.lastIndexOf('/'));
      const lastNumber = expression.slice(lastOperatorIndex + 1);
      if (!lastNumber.includes('.')) {
        if (!lastNumber) {
          expression += '0.';
        } else {
          expression += '.';
        }
        updateDisplay();
      }
    }

    function clearDisplay() {
      expression = '';
      updateDisplay();
    }

    function deleteLast() {
      expression = expression.slice(0, -1);
      updateDisplay();
    }

    function appendMinus() {
      if (!expression) {
        expression = '-';
        updateDisplay();
        return;
      }
      const lastOperatorIndex = Math.max(expression.lastIndexOf('+'), expression.lastIndexOf('-'), expression.lastIndexOf('*'), expression.lastIndexOf('/'));
      let lastNumber = expression.slice(lastOperatorIndex + 1);
      if (lastNumber.startsWith('-')) {
        expression = expression.slice(0, lastOperatorIndex + 1) + lastNumber.slice(1);
      } else {
        expression = expression.slice(0, lastOperatorIndex + 1) + '-' + lastNumber;
      }
      updateDisplay();
    }

    function calculateResult() {
      try {
        const safeEval = new Function('return ' + expression);
        const result = safeEval();
        history.push(expression + ' = ' + result);
        updateHistory();
        expression = String(result);
        updateDisplay();
      } catch {
        alert('Invalid Expression');
        expression = '';
        updateDisplay();
      }
    }

    function updateHistory() {
      const historyEl = document.getElementById('historyContainer');
      historyEl.textContent = history.slice(-10).join('\n') || 'No history yet';
    }

    function toggleHistory() {
      const historyContainer = document.getElementById('historyContainer');
      const btn = document.getElementById('toggleHistoryBtn');
      if (historyContainer.style.display === 'none') {
        historyContainer.style.display = 'block';
        btn.textContent = 'Hide History';
      } else {
        historyContainer.style.display = 'none';
        btn.textContent = 'Show History';
      }
    }

    updateDisplay();
    updateHistory();
  </script>
</body>
</html>
